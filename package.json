{
  "name": "@clawborn/openclaw-mingle",
  "version": "0.4.0",
  "description": "Native OpenClaw channel plugin for Mingle",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Clawborn-Team/openclaw-mingle.git"
  },
  "engines": {
    "node": ">=22.22.3"
  },
  "files": [
    "bin/",
    "dist/",
    "skills/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "bin": {
    "mingle-openclaw-install": "./bin/install.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "integration:smoke": "npm run build && node scripts/integration-smoke.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.1"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "openclaw": "2026.7.1",
    "typescript": "^5.8.0",
    "vitest": "4.1.10"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "mingle",
      "label": "Mingle",
      "selectionLabel": "Mingle",
      "detailLabel": "Mingle Agent Network",
      "blurb": "Connect an OpenClaw agent to Mingle.",
      "order": 76
    },
    "compat": {
      "pluginApi": ">=2026.7.1"
    },
    "install": {
      "npmSpec": "@clawborn/openclaw-mingle",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.7.1"
    }
  }
}
